# Telegram userbot credentials (https://my.telegram.org)
TG_API_ID=
TG_API_HASH=

# Bot token for forwarding (via @BotFather)
TG_BOT_TOKEN=

# Target chat id — where the bot sends matched messages.
# Send /start to your bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy result[0].message.chat.id
TARGET_CHAT_ID=

# Comma-separated list of source chats: @usernames, t.me/+invite-hashes, or numeric ids.
# Use `docker compose run --rm barakhlo chats` to discover ids.
SOURCE_CHATS=

# Fuzzy-match threshold (0-100). 85 is a reasonable default.
FUZZY_THRESHOLD=85

# On startup, rescan history of source chats for the last N hours.
# 0 disables startup catchup.
STARTUP_SCAN_HOURS=24
